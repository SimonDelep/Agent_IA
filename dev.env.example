# --- single_agent orchestrator (Responses API) ---
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=nordtrail-llm

# --- RAG retrieval (Chroma + embeddings) ---
AZURE_OPENAI_EMBEDDING_MODEL=nordtrail-embedding
CHROMA_PATH=./db/chroma_store
CHROMA_COLLECTION=nordtrail_documents
TOP_K=5

# --- Ingestion only (when running ingest scripts) ---
DOCUMENTS_FOLDER=Rag_project/documents
CHUNK_SIZE=1500
CHUNK_OVERLAP=150

# --- Optional: Azure AI Search (if you use Search ingest) ---
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_INDEX_NAME=index-rag-canadien

# --- Optional ---
DEBUG_MODE=false

# --- NordTrail API (port 8001 — évite conflit ChromaDB / port 8000) ---
NORDTRAIL_API_URL=http://127.0.0.1:8001

# --- LangSmith observability (multi_agent/) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=nordtrail-multi-agent
AUDIT_VERBOSE_TRACING=false

# --- Guardrail anti prompt-injection (multi_agent/ Streamlit) ---
GUARDRAIL_ENABLED=true
GUARDRAIL_BLOCK_MODE=hard
